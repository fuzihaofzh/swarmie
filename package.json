{
  "name": "swarmie",
  "version": "0.1.0",
  "description": "AI CLI tool aggregator — wrap Claude Code, Codex, Gemini CLI with a unified web dashboard",
  "type": "module",
  "bin": {
    "swarmie": "./dist/bin/swarmie.js"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:web": "vite build",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src bin",
    "build:app": "bash desktop/build.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "@fastify/websocket": "^11.0.2",
    "@fastify/static": "^8.1.0",
    "node-pty": "^1.0.0",
    "nanoid": "^5.1.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "zustand": "^5.0.3",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "vitest": "^3.0.0",
    "eslint": "^9.19.0",
    "@eslint/js": "^9.19.0",
    "typescript-eslint": "^8.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "bin"
  ],
  "license": "MIT"
}
